# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js (compat / legacy paths)
/.next/
/out/

# Vite / TanStack Start / Nitro
/.output/
/dist/
*.tsbuildinfo

# Cloudflare (Wrangler local state)
.wrangler/

# Production
/build

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env (opt-in to commit if needed)
.env*

# Vercel
.vercel

# TypeScript
next-env.d.ts
