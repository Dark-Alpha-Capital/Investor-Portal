{
  "name": "investor-portal",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run transit --filter=pass-the-hat",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4",
    "@tailwindcss/vite": "^4.2.2",
    "lightningcss-linux-x64-gnu": "^1.30.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.6.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
