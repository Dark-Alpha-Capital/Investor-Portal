{
  "name": "@repo/db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@repo/typescript-config": "*",
    "drizzle-kit": "^0.31.7"
  },
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema.ts",
    "./queries": "./queries.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "cd ../../apps/web && wrangler d1 migrations apply dac-investor-portal --local",
    "db:migrate:remote": "cd ../../apps/web && wrangler d1 migrations apply dac-investor-portal --remote",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  }
}
